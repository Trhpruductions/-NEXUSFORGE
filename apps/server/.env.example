PORT=4000
NODE_ENV=development
# Comma-separated web origins allowed to call the API.
# Example: https://app.nexusforge.com,https://beta.nexusforge.app
CLIENT_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexusforge
REDIS_URL=redis://localhost:6379
# Use at least 32 chars for both JWT secrets.
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30

# LiveKit (optional)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=wss://your-livekit-host

# Object storage (optional)
S3_REGION=auto
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# Web Push (optional)
WEB_PUSH_SUBJECT=mailto:admin@nexusforge.local
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=

# Upload limits
UPLOAD_MAX_BYTES=26214400
PREMIUM_UPLOAD_MAX_BYTES=157286400

# Used for Stripe redirect success/cancel URLs
APP_WEB_URL=http://localhost:3000
# For remote public testing, point this to your public web tunnel URL.
# Example: https://xxxxxxxxxxxx.trycloudflare.com

# Launch mode: set true to force desktop-only; false to allow full web access.
NEXUSFORGE_DESKTOP_ONLY=false

# Discord bot integration (optional)
DISCORD_BOT_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_PUBLIC_KEY=
DISCORD_REGISTER_COMMANDS_ON_START=true
DISCORD_ENFORCE_CLIENT_ID_MATCH=true
DISCORD_GUILD_ID=1445242974245228678
DISCORD_INSTALL_URL=https://discord.com/oauth2/authorize?client_id=<your-client-id>
DISCORD_REPORT_ENABLED=true
DISCORD_REPORT_GUILD_ID=1445242974245228678
# Optional category to scope report channel name resolution (prevents cross-category name collisions)
DISCORD_REPORT_CATEGORY_ID=
DISCORD_REPORT_CHANNEL_STATUS=bot-status
DISCORD_REPORT_CHANNEL_ERRORS=bot-errors
DISCORD_REPORT_CHANNEL_ALERTS=bot-alerts
DISCORD_REPORT_CHANNEL_SOCIAL=bot-social
DISCORD_REPORT_CHANNEL_APP_HEALTH=app-health
DISCORD_REPORT_CHANNEL_APP_RUNTIME=app-runtime
DISCORD_REPORT_CHANNEL_APP_RELEASE_OPS=app-release-ops
DISCORD_REPORT_CHANNEL_APP_SECURITY=app-security
DISCORD_REPORT_CHANNEL_APP_PERFORMANCE=app-performance
DISCORD_REPORT_CHANNEL_APP_USER_FEEDBACK=app-user-feedback
# Optional status heartbeat interval in minutes (0 disables periodic heartbeat posts)
DISCORD_REPORT_HEARTBEAT_MINUTES=0
DISCORD_SOCIAL_CHANNEL_ID=

# Stripe billing setup
# To enable billing readiness, provide STRIPE_SECRET_KEY plus every STRIPE_PRICE_* value below.
# Typical Stripe key format: sk_test_xxx or sk_live_xxx
STRIPE_SECRET_KEY=

# Optional unless you process Stripe webhooks locally/in production
# Typical webhook secret format: whsec_xxx
STRIPE_WEBHOOK_SECRET=

# Core+ tier recurring prices (Stripe Price IDs, usually price_xxx)
STRIPE_PRICE_CORE_MONTHLY=
STRIPE_PRICE_CORE_YEARLY=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_YEARLY=
STRIPE_PRICE_ELITE_MONTHLY=
STRIPE_PRICE_ELITE_YEARLY=
STRIPE_PRICE_INFINITE_MONTHLY=
STRIPE_PRICE_INFINITE_YEARLY=

# Add-on prices (Stripe Price IDs, usually price_xxx)
STRIPE_PRICE_FORGE_BOOST_PACK=
STRIPE_PRICE_CREATOR_CAMPAIGN_SLOT=
STRIPE_PRICE_EVENT_TICKET_PASS=
STRIPE_PRICE_TEAM_BRANDING_KIT=
STRIPE_PRICE_ADVANCED_MODERATION_AI=

# Industrial Security
IP_ANONYMIZATION_SALT=replace-with-secure-salt
