{
  "name": "@nexusforge/server",
  "version": "1.0.11",
  "description": "NexusForge API service",
  "scripts": {
    "dev:cleanup-port": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/cleanup-server-port.ps1",
    "dev": "npm run dev:cleanup-port && npx --yes tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "npx --yes tsx --test tests/**/*.test.ts",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed:profiles": "npx --yes tsx prisma/seed-profiles.ts",
    "seed:users": "npx --yes tsx prisma/seed-user-groups.ts",
    "seed:all": "npm run prisma:migrate && npm run seed:users && npm run seed:profiles",
    "discord:whoami": "node ./scripts/discord-token-whoami.mjs",
    "discord:verify": "node ./scripts/verify-discord-bot-config.mjs",
    "desktop:manifest:validate": "node ./scripts/validate-desktop-manifest.mjs",
    "discord:setup:channels": "node ./scripts/discord-setup-channels.mjs",
    "discord:post:download": "node ./scripts/discord-post-download-embed.mjs",
    "discord:probe": "node ./scripts/discord-report-probe.mjs",
    "discord:read-channel": "node ./scripts/discord-read-channel.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.3",
    "morgan": "^1.10.1",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "stripe": "^22.1.1",
    "web-push": "^3.6.7",
    "xss": "^1.0.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.1",
    "@types/web-push": "^3.6.4",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
