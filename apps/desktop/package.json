{
  "name": "@nexusforge/desktop",
  "version": "1.0.11",
  "private": true,
  "description": "NexusForge Desktop",
  "author": "NexusForge",
  "main": "main.js",
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-desktop.ps1",
    "dev:full": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-desktop.ps1",
    "dev:hosted": "powershell -NoProfile -Command \"$env:NEXUSFORGE_ALLOW_HOSTED_DEV='true'; $env:NEXUSFORGE_ALLOW_HOSTED_CERT_BYPASS='true'; if (-not $env:NEXUSFORGE_DESKTOP_URL -or [string]::IsNullOrWhiteSpace($env:NEXUSFORGE_DESKTOP_URL)) { $env:NEXUSFORGE_DESKTOP_URL='https://trhpruductions.github.io/-NEXUSFORGE/download.html' }; npx --yes electron --user-data-dir=\"$PWD\\.electron-profile\" --disk-cache-dir=\"$PWD\\.electron-cache\" --disable-gpu-shader-disk-cache .\"",
    "package:win": "powershell -NoProfile -Command \"$ErrorActionPreference='SilentlyContinue'; if (Test-Path 'release\\NexusForge Desktop-win32-x64') { Remove-Item 'release\\NexusForge Desktop-win32-x64' -Recurse -Force }; if (Test-Path 'release\\win-unpacked') { Remove-Item 'release\\win-unpacked' -Recurse -Force }; exit 0\" && set \"PATH=%CD%\\node_modules\\7zip-bin\\win\\x64;%PATH%\" && npx electron-builder --win nsis --publish never"
  },
  "build": {
    "appId": "com.nexusforge.desktop",
    "productName": "NexusForge Desktop",
    "electronVersion": "42.0.1",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "fallback.html",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/app-icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "NexusForge Desktop"
    }
  },
  "devDependencies": {
    "@electron/packager": "^18.3.6",
    "7zip-bin": "^5.2.0",
    "electron": "^42.0.1",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "wait-on": "^8.0.5"
  }
}

