# Desktop app environment variables

# Override the hosted web app target for Electron.
NEXUSFORGE_DESKTOP_URL=https://app.your-domain.com/app

# Durable public host for update artifacts and hosted app fallback.
NEXUSFORGE_PERSISTENT_DOWNLOAD_BASE_URL=https://downloads.your-domain.com

# If your manifest is hosted separately from the download base, use this URL.
NEXUSFORGE_UPDATE_MANIFEST_URL=https://downloads.your-domain.com/desktop-update.json

# Development-only hosted launch.
NEXUSFORGE_ALLOW_HOSTED_DEV=false

# Allow hosted TLS bypass on trusted NexusForge hostnames during rollout.
NEXUSFORGE_ALLOW_HOSTED_CERT_BYPASS=false
