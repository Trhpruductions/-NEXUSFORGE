{
  "name": "nexusforge",
  "version": "1.0.11",
  "description": "",
  "scripts": {
    "dev:cleanup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/cleanup-dev-ports.ps1",
    "dev": "npm run dev:cleanup && npx concurrently \"npm run dev -w web\" \"npm run dev -w server\"",
    "preview:live": "npm run dev:cleanup && npx concurrently --names web,api,desktop --kill-others-on-fail \"npm run dev -w web\" \"npm run dev -w server\" \"npm run dev:full -w @nexusforge/desktop\"",
    "dev:web": "npm run dev -w web",
    "dev:server": "npm run dev -w server",
    "dev:desktop": "npm run dev -w @nexusforge/desktop",
    "dev:desktop:hosted": "npm run dev:hosted -w @nexusforge/desktop",
    "beta:web": "npm run dev -w web -- --port 3100",
    "beta:api": "npm run dev -w server",
    "beta:start": "npm run dev:cleanup && npx concurrently \"npm run beta:web\" \"npm run beta:api\"",
    "beta:share": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-beta-share.ps1",
    "beta:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop-beta-share.ps1",
    "beta:tunnel:web": "npx --yes cloudflared tunnel --url http://127.0.0.1:3100",
    "beta:tunnel:api": "npx --yes cloudflared tunnel --url http://127.0.0.1:4001",
    "desktop:open": "npm run dev -w @nexusforge/desktop",
    "desktop:open:hosted": "npm run dev:hosted -w @nexusforge/desktop",
    "desktop:full": "npm run dev:cleanup && npx concurrently --names web,api,desktop --kill-others-on-fail \"npm run dev -w web\" \"npm run dev -w server\" \"npm run dev:full -w @nexusforge/desktop\"",
    "desktop:installer": "node ./scripts/desktop-installer-pipeline.mjs",
    "desktop:install:ui": "powershell -NoProfile -Command \"$installer = Get-ChildItem 'apps\\desktop\\release','apps\\desktop\\release-new' -Filter 'NexusForge Desktop Setup *.exe' -File -ErrorAction SilentlyContinue | Sort-Object LastWriteTime -Descending | Select-Object -First 1; if ($installer) { Start-Process $installer.FullName } else { Write-Error 'Installer not found. Run desktop:installer first.' }\"",
    "desktop:open:installed": "powershell -NoProfile -Command \"$registryRoots = @('HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*', 'HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*'); $registryEntry = Get-ItemProperty $registryRoots -ErrorAction SilentlyContinue | Where-Object { $_.DisplayName -match '^NexusForge Desktop' } | Select-Object -First 1; $candidatePaths = New-Object System.Collections.Generic.List[string]; if ($registryEntry) { if ($registryEntry.InstallLocation) { $candidatePaths.Add((Join-Path $registryEntry.InstallLocation 'NexusForge Desktop.exe')); } $uninstallExe = [regex]::Match($registryEntry.UninstallString, '^\\\"(.*?)\\\"').Groups[1].Value; if ($uninstallExe) { $candidatePaths.Add((Join-Path (Split-Path -Parent $uninstallExe) 'NexusForge Desktop.exe')); } } $candidatePaths.Add((Join-Path $env:LOCALAPPDATA 'Programs\\NexusForge Desktop\\NexusForge Desktop.exe')); $candidatePaths.Add('C:\\Program Files\\NexusForge Desktop\\NexusForge Desktop.exe'); $candidatePaths.Add('C:\\Program Files (x86)\\NexusForge Desktop\\NexusForge Desktop.exe'); $exe = $candidatePaths | Where-Object { Test-Path $_ } | Select-Object -First 1; if ($exe) { Start-Process $exe; return }; if ($registryEntry) { Write-Error \"NexusForge Desktop is installed, but the executable could not be resolved from registry metadata. Registry install location: $($registryEntry.InstallLocation); uninstall string: $($registryEntry.UninstallString)\" } else { Write-Error 'Installed NexusForge Desktop executable not found. Run desktop:installer first.' }\"",
    "desktop:open:unpacked": "powershell -NoProfile -Command \"$exe = Resolve-Path 'apps\\desktop\\release\\win-unpacked\\NexusForge Desktop.exe' -ErrorAction SilentlyContinue; if ($exe) { Start-Process $exe.Path } else { Write-Error 'Unpacked executable not found. Run desktop:installer first.' }\"",
    "desktop:share": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1",
    "desktop:share:temp": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1 -Bump none -AllowEphemeral",
    "desktop:share:temp:patch": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1 -Bump patch -AllowEphemeral",
    "desktop:share:temp:force": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1 -Bump none -AllowEphemeral -AllowUnresolvedTunnelHostnames -SkipDownloadUrlValidation",
    "desktop:share:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1 -Bump none -PersistentBaseUrl http://127.0.0.1:3200 -AllowEphemeral",
    "desktop:share:local:force": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1 -Bump none -PersistentBaseUrl http://127.0.0.1:3200 -AllowEphemeral -ForceUpdate",
    "desktop:share:local:patch": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1 -Bump patch -PersistentBaseUrl http://127.0.0.1:3200 -AllowEphemeral",
    "desktop:share:persistent": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1 -Bump none -PersistentBaseUrl $env:NEXUSFORGE_PERSISTENT_DOWNLOAD_BASE_URL",
    "desktop:share:persistent:force": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1 -Bump none -PersistentBaseUrl $env:NEXUSFORGE_PERSISTENT_DOWNLOAD_BASE_URL -ForceUpdate",
    "desktop:share:persistent:patch": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1 -Bump patch -PersistentBaseUrl $env:NEXUSFORGE_PERSISTENT_DOWNLOAD_BASE_URL",
    "desktop:release:checklist": "node ./scripts/desktop-release-checklist.mjs",
    "desktop:release:bundle": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/prepare-desktop-web-release.ps1",
    "desktop:release:deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/deploy-desktop-web-release.ps1",
    "desktop:release:deploy:env": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-deploy-from-env.ps1",
    "desktop:release:deploy:env:insecure": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-deploy-from-env.ps1 -VerifyInsecure",
    "desktop:share:patch": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1 -Bump patch",
    "desktop:share:none": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1 -Bump none",
    "desktop:share:force": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1 -Bump patch -ForceUpdate",
    "desktop:share:minor": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1 -Bump minor",
    "desktop:share:major": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-release-share.ps1 -Bump major",
    "desktop:update:validate": "node ./scripts/validate-desktop-update-endpoints.mjs",
    "desktop:update:validate:insecure": "node ./scripts/validate-desktop-update-endpoints.mjs --insecure",
    "desktop:update:validate:local": "node ./scripts/validate-desktop-update-endpoints.mjs --base http://127.0.0.1:3000 --insecure",
    "desktop:release:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/verify-desktop-release.ps1",
    "desktop:release:verify:insecure": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/verify-desktop-release.ps1 -Insecure",
    "desktop:network:validate": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/validate-desktop-network-modes.ps1 -Mode all",
    "desktop:network:validate:allow-fallback": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/validate-desktop-network-modes.ps1 -Mode all -AllowFallback",
    "desktop:network:validate:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/validate-desktop-network-modes.ps1 -Mode local",
    "desktop:network:validate:hosted": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/validate-desktop-network-modes.ps1 -Mode hosted",
    "discord:probe": "npm run discord:probe -w @nexusforge/server",
    "age:gate:validate": "node ./scripts/validate-age-gate-security.mjs",
    "age:gate:validate:local": "node ./scripts/validate-age-gate-security.mjs --base http://127.0.0.1:3000",
    "brand:verify": "node ./scripts/verify-brand-assets.mjs",
    "admin:badge:smoke": "node ./scripts/admin-badge-smoke.mjs",
    "scripts:validate:powershell": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/validate-powershell-scripts.ps1",
    "smoke:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/local-smoke.ps1",
    "smoke:release-gate": "npm run smoke:local && npm run desktop:network:validate:ci",
    "smoke:release-gate:strict": "npm run smoke:local && npm run desktop:network:validate:ci:strict",
    "ops:validate": "npm run smoke:release-gate && npm run discord:probe",
    "ops:validate:strict": "npm run smoke:release-gate:strict && npm run discord:probe",
    "ops:validate:soak": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ops-validate-soak.ps1 -Runs 3",
    "ops:validate:soak:strict": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ops-validate-soak.ps1 -Runs 3 -Strict",
    "ops:validate:soak:quick": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ops-validate-soak.ps1 -Runs 1",
    "ops:validate:soak:quick:strict": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ops-validate-soak.ps1 -Runs 1 -Strict",
    "ops:validate:soak:deep": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ops-validate-soak.ps1 -Runs 10",
    "ops:validate:soak:deep:strict": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ops-validate-soak.ps1 -Runs 10 -Strict",
    "ops:validate:soak:deep:archive": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ops-validate-soak.ps1 -Runs 10 -ArchiveReports",
    "ops:validate:soak:deep:strict:archive": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ops-validate-soak.ps1 -Runs 10 -Strict -ArchiveReports",
    "ops:validate:soak:history:summary": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ops-soak-history-summary.ps1",
    "ops:validate:soak:history:summary:strict": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ops-soak-history-summary.ps1 -StrictOnly",
    "ops:validate:soak:history:guard:strict": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ops-soak-history-summary.ps1 -StrictOnly -EnforceThresholds -ThresholdWindowCount 1 -MinReportCount 1 -MinTotalRuns 1 -MinPassRate 100 -MaxWeightedAvgRunDurationMs 130000 -MaxLatestAvgRunDurationMs 130000 -MaxLatestAvgRunDurationDeltaMs 90000 -MaxSampleRunDurationMs 140000 -MaxP95RunDurationMs 130000",
    "ops:validate:soak:history:guard:strict:full": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ops-soak-history-summary.ps1 -StrictOnly -EnforceThresholds -ThresholdWindowCount 1 -MinReportCount 1 -MinTotalRuns 10 -MinPassRate 100 -MaxWeightedAvgRunDurationMs 90000 -MaxLatestAvgRunDurationMs 90000 -MaxLatestAvgRunDurationDeltaMs 30000 -MaxSampleRunDurationMs 120000 -MaxP95RunDurationMs 90000",
    "ops:validate:candidate:quick": "npm run scripts:validate:powershell && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ops-validate-soak.ps1 -Runs 1 -Strict -ArchiveReports && npm run ops:validate:soak:history:guard:strict",
    "ops:validate:candidate": "npm run scripts:validate:powershell && npm run ops:validate:soak:deep:strict:archive && npm run ops:validate:soak:history:guard:strict:full",
    "ops:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-doctor.ps1",
    "ops:doctor:archive": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-doctor.ps1 -ArchiveReport",
    "desktop:network:validate:ci": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/validate-desktop-network-modes.ps1 -Mode all -AllowFallback -ReportPath ./apps/desktop/.network-smoke/latest-report.json",
    "desktop:network:validate:ci:strict": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/validate-desktop-network-modes.ps1 -Mode all -ReportPath ./apps/desktop/.network-smoke/latest-report.json",
    "build": "node ./scripts/build-workspace.mjs",
    "lint": "npm run lint -w web"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "devDependencies": {
    "7zip-bin": "^5.2.0",
    "concurrently": "^9.2.1",
    "enhanced-resolve": "^5.21.2"
  },
  "dependencies": {
    "date-fns": "^4.1.0"
  }
}
