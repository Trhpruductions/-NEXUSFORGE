{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "types": ["node"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@nexusforge/ui": ["packages/ui/src"],
      "@nexusforge/types": ["packages/types/src"]
    }
  },
  "files": [],
  "references": [
    { "path": "./packages/types" },
    { "path": "./packages/ui" },
    { "path": "./apps/server" }
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "apps/web/.next",
    "apps/web/.next-dev",
    "apps/web/.next-build"
  ]
}
