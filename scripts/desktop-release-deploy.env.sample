# Copy this file to scripts/desktop-release-deploy.env and fill values.
# Then run: npm run desktop:release:deploy:env

NEXUSFORGE_DEPLOY_HOST=your-host.example.com
NEXUSFORGE_DEPLOY_USER=deploy
NEXUSFORGE_DEPLOY_WEBROOT=/var/www/nexusforge
NEXUSFORGE_DEPLOY_PORT=22

# Optional: absolute path to private key used by ssh/scp.
# NEXUSFORGE_DEPLOY_SSH_KEY_PATH=C:/Users/you/.ssh/id_rsa

# Optional: if set, nginx snippet is uploaded and nginx is reloaded remotely.
# NEXUSFORGE_DEPLOY_NGINX_SNIPPET_PATH=/etc/nginx/snippets/nexusforge-desktop-release.conf

# Optional artifact integrity thresholds used by deploy preflight validator.
# Defaults: installer >= 41943040 bytes, app.asar >= 10485760 bytes.
# NEXUSFORGE_MIN_INSTALLER_BYTES=41943040
# NEXUSFORGE_MIN_APP_ASAR_BYTES=10485760
